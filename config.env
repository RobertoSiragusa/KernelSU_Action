CONFIG_ENV=config.env

# =========================
# KERNEL SOURCE
# =========================
KERNEL_SOURCE=https://github.com/RobertoSiragusa/dbyw09
KERNEL_SOURCE_BRANCH=main

# =========================
# BUILD TARGET
# =========================
ARCH=arm64
KERNEL_CONFIG=vendor_kona_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ADD_LOCALVERSION_TO_FILENAME=false

# =========================
# COMPILER
# =========================
USE_CUSTOM_CLANG=true

# Tripla corretta
CLANG_TRIPLE=aarch64-linux-android-4.9

CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r450784e

# GCC (opzionale)
ENABLE_GCC_ARM64=false
ENABLE_GCC_ARM32=false
USE_CUSTOM_GCC_64=true
USE_CUSTOM_GCC_32=false

# =========================
# KERNELSU
# =========================
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

APPLY_KSU_PATCH=false

# =========================
# BUILD OPTIONS
# =========================
EXTRA_CMDS=LLVM=1 LLVM_IAS=1

DISABLE_LTO=false
DISABLE_CC_WERROR=false
ADD_KPROBES_CONFIG=false
ADD_OVERLAYFS_CONFIG=false

REMOVE_UNUSED_PACKAGES=true

# =========================
# PERFORMANCE
# =========================
ENABLE_CCACHE=true

# =========================
# DTBO / BOOT
# =========================
NEED_DTBO=false
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=

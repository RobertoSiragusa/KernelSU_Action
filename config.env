CONFIG_ENV=config.env

# =========================
# KERNEL SOURCE
# =========================
KERNEL_SOURCE=https://github.com/RobertoSiragusa/dbyw09
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=vendor/merge_kona_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false

# =========================
# CLANG (PROTON)
# =========================
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/kdrag0n/proton-clang.git
CUSTOM_CLANG_BRANCH=main

# =========================
# GCC (NECESSARIO)
# =========================
ENABLE_GCC_64=true
ENABLE_GCC_32=true
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# =========================
# TOOLCHAIN
# =========================
CUSTOM_CMDS="\
CLANG_TRIPLE=aarch64-linux-gnu- \
CROSS_COMPILE=aarch64-linux-android-4.9 \
CROSS_COMPILE_ARM32=arm-linux-androideabi-4.9 \
CC=clang \
LD=ld.lld \
AR=llvm-ar \
NM=llvm-nm \
OBJCOPY=llvm-objcopy \
OBJDUMP=llvm-objdump \
STRIP=llvm-strip \
"

# =========================
# EXTRA FLAGS
# =========================
EXTRA_CMDS="LLVM=1"

# =========================
# KERNELSU
# =========================
ENABLE_KERNELSU=false

# =========================
# BUILD FIXES
# =========================
DISABLE_LTO=true
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=false
ADD_OVERLAYFS_CONFIG=false
APPLY_KSU_PATCH=false
REMOVE_UNUSED_PACKAGES=true

# =========================
# ANYKERNEL3
# =========================
USE_CUSTOM_ANYKERNEL3=false

# =========================
# CACHE
# =========================
ENABLE_CCACHE=true

# =========================
# DTBO
# =========================
NEED_DTBO=false

# =========================
# BOOT IMG
# =========================
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/xiaoleGun/KernelSU_action/main/boot/boot.img
